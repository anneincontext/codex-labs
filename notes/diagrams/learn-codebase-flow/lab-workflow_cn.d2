# Lab 工作流：prompt → 持久结果
# Render: d2 --layout dagre lab-workflow_cn.d2 lab-workflow_cn.svg

direction: down

phase_a: "阶段 A — 启动" {
  style.fill: "#E8F4FC"
  open_repo: "在 Codex 工作区打开目标仓库"
  prompt: "learn-repo-overview prompt\n（做什么 / 架构 / 目录 / 流 / 栈）"
  mental: "聊天里的 mental model"
  open_repo -> prompt -> mental
}

phase_b: "阶段 B — Zoom" {
  style.fill: "#FFF8E8"
  examples: "短 follow-up" {
    ex1: "和目录名对齐的图"
    ex2: "跟完一次 user turn 端到端"
    ex3: "若要改 X，先读哪里？"
  }
  rule: "一层或一条路径一轮"
  examples -> rule
}

phase_c: "阶段 C — 缓存" {
  style.fill: "#E8FCE8"
  notes: "写入或打磨 notes/\n（如 architecture、layeredDesign）"
  reuse: "下次会话直接复用"
  notes -> reuse
}

phase_a -> phase_b -> phase_c