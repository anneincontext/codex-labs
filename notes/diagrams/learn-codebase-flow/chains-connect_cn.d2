# 两条链如何接上
# Render: d2 --layout dagre chains-connect_cn.d2 chains-connect_cn.svg

direction: down

prompt: "总览 prompt\n（五问）" {
  style.fill: "#E8F4FC"
}

turn: "Codex 轮次\nUserInput → 上下文 → API ↔ 工具(仓库)" {
  style.fill: "#FFF8E8"
}

chat: "聊天里的答案\n（即时）" {
  style.fill: "#E8FCE8"
}

notes: "notes/\n（持久）" {
  style.fill: "#E8FCE8"
}

prompt -> turn
turn -> chat: "即时"
turn -> notes: "你的 follow-up"